# XYO Prediction Market dApp - Environment Variables
# Copy this file to .env.local and fill in the values

# XYO Wallet Mnemonic (12 or 24 words)
# Generate with: npx @xyo-network/sdk-js generate-mnemonic
# SECURITY: Never commit your actual mnemonic to version control
MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# XL1 Network Configuration (Sequence Testnet)
XL1_RPC_URL="https://sequence.xyo.network"
XL1_CHAIN_ID="1"

# Game Configuration
BOT_DIFFICULTY="medium"  # easy | medium | hard
ROUND_TIMEOUT_SECONDS="30"
